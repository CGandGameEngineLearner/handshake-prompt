{
  "name": "handshake-prompt-client",
  "version": "0.1.0",
  "description": "Browser SDK for the Handshake Prompt Protocol - let users grant AI Agents access to your web service via a single copy-paste prompt",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev":   "tsup src/index.ts --format esm --dts --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai", "agent", "llm", "handshake", "websocket", "protocol",
    "automation", "browser", "client"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CGandGameEngineLearner/handshake-prompt.git",
    "directory": "libs/js"
  },
  "homepage": "https://github.com/CGandGameEngineLearner/handshake-prompt",
  "bugs": "https://github.com/CGandGameEngineLearner/handshake-prompt/issues",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
